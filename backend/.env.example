APP_NAME=AegisCX
APP_VERSION=1.0.0
ENVIRONMENT=development
DEBUG=false
LOG_LEVEL=INFO
USE_CELERY=false

SECRET_KEY=CHANGE-ME-TO-A-LONG-RANDOM-32-PLUS-CHARACTER-SECRET
ACCESS_TOKEN_EXPIRE_MINUTES=30
REFRESH_TOKEN_EXPIRE_DAYS=7

# Use PostgreSQL in production. For simple local runs, any non-PostgreSQL value
# causes the app to fall back to SQLite automatically.
DATABASE_URL=sqlite+aiosqlite:///./data/aegiscx.db
DATABASE_URL_SYNC=sqlite:///./data/aegiscx.db

REDIS_URL=redis://localhost:6379/0
CELERY_BROKER_URL=redis://localhost:6379/0
CELERY_RESULT_BACKEND=redis://localhost:6379/1
LLM_CACHE_TTL_SECONDS=3600

CORS_ORIGINS=http://localhost:3000,http://127.0.0.1:3000

MAX_FILE_SIZE_GB=1
WHISPER_MODEL_SIZE=base
WHISPER_DEVICE=cpu
WHISPER_COMPUTE_TYPE=int8

HF_TOKEN=
GOOGLE_API_KEY=
MISTRAL_API_KEY=
OPENAI_API_KEY=

LLM_CONFIDENCE_THRESHOLD=0.75
LLM_PRIMARY_MODEL=models/gemini-2.5-flash
LLM_FALLBACK_MODEL=gpt-4o

EMBEDDING_MODEL=all-MiniLM-L6-v2
SENTIMENT_MODEL=cardiffnlp/twitter-roberta-base-sentiment-latest
EMOTION_MODEL=j-hartmann/emotion-english-distilroberta-base
INTENT_MODEL=valhalla/distilbart-mnli-12-1
NER_MODEL=dslim/bert-base-NER
MC_DROPOUT_PASSES=10

AUDIO_CHUNK_DURATION=30
AUDIO_CHUNK_OVERLAP=5
MAX_CONCURRENT_JOBS=5
JOB_TIMEOUT_SECONDS=3600
