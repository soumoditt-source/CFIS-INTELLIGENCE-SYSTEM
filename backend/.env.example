# AegisCX backend environment template
# Copy to backend/.env for local work. Keep real secrets out of git.

# App
APP_NAME=AegisCX
APP_VERSION=1.0.0
ENVIRONMENT=development
DEBUG=false
LOG_LEVEL=INFO
USE_CELERY=false

# Security
SECRET_KEY=replace_with_a_random_string_at_least_32_characters_long
ACCESS_TOKEN_EXPIRE_MINUTES=30
REFRESH_TOKEN_EXPIRE_DAYS=7

# Database
# Local development can stay on SQLite.
DATABASE_URL=sqlite+aiosqlite:///./data/aegiscx.db
DATABASE_URL_SYNC=sqlite:///./data/aegiscx.db

# Redis and caching
REDIS_URL=redis://localhost:6379/0
CELERY_BROKER_URL=redis://localhost:6379/0
CELERY_RESULT_BACKEND=redis://localhost:6379/1
LLM_CACHE_TTL_SECONDS=3600

# CORS
# Comma-separated list is supported.
CORS_ORIGINS=http://localhost:3000,http://127.0.0.1:3000

# File handling
DATA_DIR=./data
RAW_AUDIO_DIR=./data/raw
PROCESSED_AUDIO_DIR=./data/processed
CHROMADB_DIR=./data/chromadb
LOG_DIR=./logs
MAX_FILE_SIZE_GB=1.0
ALLOWED_EXTENSIONS=mp3,mp4,wav,m4a,webm,ogg,flac,mpeg

# Speech-to-text defaults
WHISPER_MODEL_SIZE=base
WHISPER_DEVICE=cpu
WHISPER_COMPUTE_TYPE=int8

# Optional model credentials
HF_TOKEN=
GOOGLE_API_KEY=
MISTRAL_API_KEY=
OPENAI_API_KEY=

# LLM orchestration
LLM_CONFIDENCE_THRESHOLD=0.75
LLM_PRIMARY_MODEL=models/gemini-2.5-flash
LLM_FALLBACK_MODEL=gpt-4o

# Local NLP defaults
EMBEDDING_MODEL=all-MiniLM-L6-v2
SENTIMENT_MODEL=cardiffnlp/twitter-roberta-base-sentiment-latest
EMOTION_MODEL=j-hartmann/emotion-english-distilroberta-base
INTENT_MODEL=valhalla/distilbart-mnli-12-1
NER_MODEL=dslim/bert-base-NER
MC_DROPOUT_PASSES=10
BERTOPIC_MIN_TOPIC_SIZE=5

# Processing
AUDIO_CHUNK_DURATION=30
AUDIO_CHUNK_OVERLAP=5
MAX_CONCURRENT_JOBS=5
JOB_TIMEOUT_SECONDS=3600
