# AegisCX Backend — Environment Variables Template
# Copy this file to .env and fill in your real values.
# NEVER commit the real .env file to git.

# ── App ─────────────────────────────────────────────────────────────────────
APP_NAME=AegisCX Intelligence Platform
ENVIRONMENT=development          # development | production
DEBUG=false
SECRET_KEY=REPLACE_WITH_64_CHAR_RANDOM_STRING   # python -c "import secrets; print(secrets.token_hex(32))"
ACCESS_TOKEN_EXPIRE_MINUTES=60
REFRESH_TOKEN_EXPIRE_DAYS=7

# ── Database ─────────────────────────────────────────────────────────────────
# Leave blank for SQLite (local dev). Set PostgreSQL URL for production.
DATABASE_URL=
# Example PostgreSQL: postgresql+asyncpg://user:password@host:5432/dbname

# ── CORS ─────────────────────────────────────────────────────────────────────
# Your Netlify frontend URL (no trailing slash)
ALLOWED_ORIGINS=["http://localhost:3000","https://YOUR-SITE.netlify.app"]

# ── LLM API Keys ─────────────────────────────────────────────────────────────
GOOGLE_API_KEY=your_google_gemini_api_key_here
MISTRAL_API_KEY=your_mistral_api_key_here
OPENAI_API_KEY=your_openai_api_key_here

# ── HuggingFace ──────────────────────────────────────────────────────────────
HF_TOKEN=your_huggingface_token_here

# ── STT / Audio ──────────────────────────────────────────────────────────────
WHISPER_MODEL_SIZE=base          # tiny | base | small | medium | large-v3
STT_COMPUTE_TYPE=int8
STT_DEVICE=cpu
USE_FASTER_WHISPER=true

# ── NLP Models ───────────────────────────────────────────────────────────────
SENTIMENT_MODEL=cardiffnlp/twitter-roberta-base-sentiment-latest
EMOTION_MODEL=j-hartmann/emotion-english-distilroberta-base
NER_MODEL=dslim/bert-base-NER

# ── LLM Selection ────────────────────────────────────────────────────────────
PRIMARY_LLM_PROVIDER=gemini
PRIMARY_LLM_MODEL=gemini-1.5-flash-latest
FALLBACK_LLM_PROVIDER=mistral
FALLBACK_LLM_MODEL=mistral-small-latest

# ── File Upload ───────────────────────────────────────────────────────────────
MAX_FILE_SIZE_MB=500
UPLOAD_DIR=./data/raw
PROCESSED_DIR=./data/processed

# ── Task Queue ────────────────────────────────────────────────────────────────
USE_CELERY=false                 # false = inline processor (no Redis needed)
CELERY_BROKER_URL=redis://localhost:6379/0

# ── Logging ───────────────────────────────────────────────────────────────────
LOG_LEVEL=INFO
LOG_DIR=./logs
